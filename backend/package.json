{
  "name": "biyahehub-api",
  "version": "1.0.0",
  "description": "Local Express + MySQL API for BiyaheHub",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node server.ts --watch . --ext ts",
    "start": "ts-node server.ts",
    "build": "tsc",
    "serve": "node dist/server.js"
  },
  "dependencies": {
    "cheerio": "1.0.0",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "^4.22.1",
    "mysql2": "^3.22.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "nodemon": "3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
